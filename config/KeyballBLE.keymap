#define ZMK_POINTING_DEFAULT_SCRL_VAL 120    // default: 10

#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>

#define MOUSE 4
#define SCROLL 5
#define NUM 6

&mt {
    flavor = "balanced";
    quick-tap-ms = <0>;
};

/ {
    combos {
        compatible = "zmk,combos";

        double_quotation {
            bindings = <&kp DOUBLE_QUOTES>;
            key-positions = <20 21>;
        };

        mb1_mb2_to_layer5 {
            bindings = <&mo 5>;
            key-positions = <22 23>;
            timeout-ms = <50>;
            slow-release;
            layers = <4>;
        };
    };

    macros {
        to_layer_0: to_layer_0 {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            bindings = <&to 0 &macro_param_1to1 &kp MACRO_PLACEHOLDER>;
            label = "TO_LAYER_0";
        };
    };

behaviors {
    lt_to_layer_0: lt_to_layer_0 {
        compatible = "zmk,behavior-hold-tap";
        label = "LAYER_TAP_TO_0";
        bindings = <&mo>, <&to_layer_0>;

        #binding-cells = <2>;
        tapping-term-ms = <200>;
    };

    ROTATE: ROTATE {
        compatible = "zmk,behavior-sensor-rotate-var";
        label = "ROTATE";
        #sensor-binding-cells = <2>;
        bindings = <&msc>, <&msc>;
        tap-ms = <20>;
    };

    /*
     * 短押し：マウスボタン（例: RCLK）
     * ホールド：レイヤー（例: 5 = scroll layer）
     * 使い方例: &mclk_or_scroll 5 RCLK
     */
    mclk_or_scroll: mclk_or_scroll {
        compatible = "zmk,behavior-hold-tap";
        label = "MCLK_OR_SCROLL";
        #binding-cells = <2>;
        flavor = "balanced";
        tapping-term-ms = <200>;
        quick-tap-ms = <0>;
        bindings = <&mo>, <&mkp>;
    };

    /*
     * 例: &rc_or_mclk MCLK RCLK のように2つ渡して使う
     * 使い方の例は残すが、用途に合わせて keymap 側で使う/使わないは自由
     */
    rc_or_mclk: rc_or_mclk {
        compatible = "zmk,behavior-hold-tap";
        label = "RC_OR_MCLK";
        #binding-cells = <2>;
        flavor = "balanced";
        tapping-term-ms = <200>;
        quick-tap-ms = <0>;
        bindings = <&mkp>, <&mkp>;
    };

    /*
     * --- Windows 106/109 補正用（Shift時の出力を mod-morph で切替）---
     * 使い方例:
     *   物理「-」キー位置 -> &win_minus_under
     *   物理「;」キー位置 -> &win_colon_semi
     *   物理「[」キー位置 -> &win_lbracket_lbrace
     *   物理「]」キー位置 -> &win_rbracket_rbrace
     */

    /* 物理「-」:  通常 '-' / Shift '_' を狙う（JP106では '_' が BSLH 側に乗ってることが多い） */
    win_minus_under: win_minus_under {
        compatible = "zmk,behavior-mod-morph";
        label = "WIN_MINUS_UNDER";
        #binding-cells = <0>;
        mods = <(MOD_LSFT|MOD_RSFT)>;
        bindings = <&kp MINUS>, <&kp BSLH>;
    };

    /* 物理「=」: 通常 '+' / Shift '=' を狙う（通常は LS(SEMI) で '+'、Shift時は MINUS で '=' を狙う） */
    win_plus_equal: win_plus_equal {
        compatible = "zmk,behavior-mod-morph";
        label = "WIN_PLUS_EQUAL";
        #binding-cells = <0>;
        mods = <(MOD_LSFT|MOD_RSFT)>;
        bindings = <&kp LS(SEMI)>, <&kp MINUS>;
    };

    /*
     * 「物理 = キーを 長押しで Layer4 を残したい」用
     * 使い方: keymap 側で「物理=キー位置」を  &win_layer4_plus_equal 4  にする
     * （= 押しっぱなしで layer4、短押しは win_plus_equal）
     */
    win_layer4_plus_equal: win_layer4_plus_equal {
        compatible = "zmk,behavior-hold-tap";
        label = "WIN_LAYER4_PLUS_EQUAL";
        #binding-cells = <1>;
        flavor = "balanced";
        tapping-term-ms = <200>;
        quick-tap-ms = <0>;
        bindings = <&mo>, <&win_plus_equal>;
    };

    /* 物理「;」: 通常 ':' / Shift ';' を狙う（JP配列で ':' をどのキーに割り当てるかは環境差あり）
       まずは “確実に ':' を出す” ため、LS(SCLN) ではなく ZMK側で COLON を使う構成にする。
       もし Windows 側で ':' にならない場合は、後であなたの実測に合わせてここを調整する。 */
    win_colon_semi: win_colon_semi {
        compatible = "zmk,behavior-mod-morph";
        label = "WIN_COLON_SEMI";
        #binding-cells = <0>;
        mods = <(MOD_LSFT|MOD_RSFT)>;
        bindings = <&kp COLON>, <&kp SEMI>;
    };

    /* '[' / '{' */
    win_lbracket_lbrace: win_lbracket_lbrace {
        compatible = "zmk,behavior-mod-morph";
        label = "WIN_LBKT_LBRC";
        #binding-cells = <0>;
        mods = <(MOD_LSFT|MOD_RSFT)>;
        bindings = <&kp LBKT>, <&kp LS(LBKT)>;
    };

    /* ']' / '}' */
    win_rbracket_rbrace: win_rbracket_rbrace {
        compatible = "zmk,behavior-mod-morph";
        label = "WIN_RBKT_RBRC";
        #binding-cells = <0>;
        mods = <(MOD_LSFT|MOD_RSFT)>;
        bindings = <&kp RBKT>, <&kp LS(RBKT)>;
    };
};
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
&kp ESC     &kp Q     &kp W     &kp E   &kp R  &kp T                                                 &kp Y        &kp U  &kp I      &kp O    &kp P        &kp MINUS
&kp TAB     &lt 4 A   &kp S     &kp D   &kp F  &kp G        &mclk_or_scroll 5 MCLK    &kp LC(UP)     &kp H        &kp J  &kp K      &kp L    &lt 4 EQUAL  &kp SEMI
&kp LSHIFT  &kp Z     &kp X     &kp C   &kp V  &kp B        &kp LC(LEFT)              &kp LC(RIGHT)  &kp N        &kp M  &kp COMMA  &kp DOT  &kp SLASH    &mt RSHFT LBKT
&kp LGUI    &kp LALT  &kp LGUI  &trans  &mo 6  &lt 3 SPACE  &lt 2 LANG2               &lt 2 LANG1    &lt 3 ENTER                             &kp RALT     &mt LGUI RBKT
            >;

            sensor-bindings = <&ROTATE SCRL_DOWN SCRL_UP>;
        };

        layer_1 {
            bindings = <
&kp ESC     &kp Q     &kp W     &kp E   &kp R  &kp T                                               &kp Y        &kp U  &kp I      &kp O    &kp P                     &win_minus_under
&kp TAB     &lt 4 A   &kp S     &kp D   &kp F  &kp G        &mclk_or_scroll 5 MCLK    &kp LG(TAB)  &kp H        &kp J  &kp K      &kp L    &win_layer4_plus_equal 4  &win_colon_semi
&kp LSHIFT  &kp Z     &kp X     &kp C   &kp V  &kp B        &kp LS(LA(TAB))           &kp LA(TAB)  &kp N        &kp M  &kp COMMA  &kp DOT  &kp SLASH                 &mt RSHFT RBKT
&kp LCTRL   &kp LALT  &kp LGUI  &trans  &mo 6  &lt 3 SPACE  &lt 2 INT5                &lt 2 INT4   &lt 3 ENTER                             &kp RALT                  &mt LCTRL BSLH
            >;

            sensor-bindings = <&ROTATE SCRL_DOWN SCRL_UP>;
        };

        layer_2 {
            bindings = <
&trans  &trans    &trans   &trans    &trans     &trans                      &trans   &trans       &trans         &trans        &trans       &trans
&trans  &kp EXCL  &kp DQT  &kp HASH  &kp DLLR   &kp BSPC  &trans    &trans  &kp DEL  &kp PERCENT  &kp AMPERSAND  &kp SQT       &kp AT_SIGN  &kp TILDE
&trans  &trans    &trans   &trans    &kp GRAVE  &trans    &trans    &trans  &trans   &kp CARET    &kp PIPE       &kp ASTERISK  &kp UNDER    &kp LEFT_PARENTHESIS
&trans  &trans    &trans   &trans    &trans     &trans    &trans    &trans  &trans                                             &trans       &kp RIGHT_PARENTHESIS
            >;

            sensor-bindings = <&ROTATE SCRL_DOWN SCRL_UP>;
        };

        layer_3 {
            bindings = <
&trans  &kp SLASH  &kp N7      &kp N8  &kp N9  &trans                       &trans   &kp F7  &kp F8  &kp F9  &kp F10  &trans
&trans  &kp ASTRK  &kp N4      &kp N5  &kp N6  &kp BSPC   &trans    &trans  &kp DEL  &kp F4  &kp F5  &kp F6  &kp F11  &trans
&trans  &kp MINUS  &kp N1      &kp N2  &kp N3  &kp EQUAL  &trans    &trans  &trans   &kp F1  &kp F2  &kp F3  &kp F12  &trans
&trans  &kp PLUS   &kp PERIOD  &kp N0  &trans  &trans     &trans    &trans  &trans                           &trans   &trans
            >;

            sensor-bindings = <&inc_dec_kp LC(PAGE_UP) LC(PAGE_DOWN)>;
        };

        layer_4 {
            bindings = <
&trans  &trans  &kp HOME        &kp UP_ARROW    &kp PAGE_UP      &trans                      &trans   &mkp MB4        &kp UP_ARROW    &kp PAGE_UP    &kp HOME         &trans
&trans  &trans  &kp LEFT_ARROW  &kp DOWN_ARROW  &kp RIGHT_ARROW  &kp BSPC  &trans    &trans  &kp DEL  &none           &mkp MB1        &mclk_or_scroll 5 RCLK  &trans  &trans
&trans  &trans  &kp END         &trans          &kp PAGE_DOWN    &trans    &trans    &trans  &trans   &kp END         &mkp MB5        &kp DOWN_ARROW  &kp PAGE_DOWN  &trans
&trans  &trans  &trans          &trans          &trans           &trans    &trans    &trans  &trans   &kp LEFT_ARROW  &kp RIGHT                                &trans  &trans
            >;

            sensor-bindings = <&ROTATE SCRL_DOWN SCRL_UP>;
        };

        layer_5 {
            bindings = <
&trans  &trans  &trans  &trans  &trans  &trans                            &kp HOME   &mkp MB4  &kp UP_ARROW    &kp PAGE_UP    &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans  &trans    &trans          &trans     &trans    &mkp MB1        &mkp MB2       &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans  &trans    &trans          &kp END    &mkp MB5  &kp DOWN_ARROW  &kp PAGE_DOWN  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans  &trans    &kp LEFT_ARROW  &kp RIGHT                                           &trans  &trans
            >;

            sensor-bindings = <&ROTATE SCRL_DOWN SCRL_UP>;
        };

        layer_6 {
            bindings = <
&trans  &trans  &trans  &trans  &trans  &trans                    &bt BT_SEL 0   &bt BT_SEL 1   &bt BT_SEL 2   &bt BT_SEL 3   &bt BT_SEL 4   &trans
&trans  &trans  &trans  &trans  &trans  &trans  &trans    &trans  &to 0          &to 0          &to 0          &to 1          &to 0          &trans
&trans  &trans  &trans  &trans  &trans  &trans  &trans    &trans  &bt BT_DISC 0  &bt BT_DISC 1  &bt BT_DISC 2  &bt BT_DISC 3  &bt BT_DISC 4  &trans
&trans  &trans  &trans  &trans  &trans  &trans  &trans    &trans  &trans                                                      &trans         &bt BT_CLR
            >;
        };
    };
};
